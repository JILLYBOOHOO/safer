PORT=3000
NODE_ENV=development

# MySQL DB configuration
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=safer_db
DB_PORT=3306

# Encryption key. Must be exactly 32 bytes (64 hex characters)
DB_ENCRYPTION_KEY=643765327438392f413d4547444b4c4d4e4f505152535455565758595a616263

# JWT secret
JWT_SECRET=super_secret_session_token_key_change_me_in_production

# Supabase configuration for emergency media uploads
SUPABASE_URL=https://your-supabase-project.supabase.co
SUPABASE_KEY=your-supabase-anon-key
SUPABASE_BUCKET=emergency-media-logs

# Emergency RTSP stream configuration
EMERGENCY_RTSP_STREAM=rtsp://192.168.1.100:554/stream1

# WhatsApp contact to receive fallback/emergency messages (e.g. 18765551234)
EMERGENCY_CONTACT_PHONE=18765551234

# OpenWeatherMap API key (free tier at openweathermap.org)
OPENWEATHER_API_KEY=your_openweathermap_api_key_here
